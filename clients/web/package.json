{
  "name": "@traycer-clients/web",
  "description": "Traycer browser shell + Bun serve process: hosts the gui-app renderer as a webapp on a Linux machine running the Traycer host.",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "serve": "bun src/server/serve.ts",
    "compile": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --cache --fix --max-warnings 0",
    "format": "bun x prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0"
}
