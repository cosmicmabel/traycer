{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": false,
    "allowImportingTsExtensions": true,
    "types": ["node", "bun"],
    "baseUrl": ".",
    "paths": {
      "@cic/protocol/utils/*": ["../protocol/utils/*"],
      "@cic/protocol/*": ["../protocol/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
